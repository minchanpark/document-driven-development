{
  "document-driven-development": {
    "PreToolUse": [
      {
        "matcher": "run_command|write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${extensionPath}/scripts/antigravity_pre_tool.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "type": "command",
        "command": "python3 \"${extensionPath}/scripts/antigravity_pre_invocation.py\"",
        "timeout": 30
      }
    ]
  }
}
